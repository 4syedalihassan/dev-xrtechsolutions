{
    "buildCommand": "npm run build",
    "framework": "nextjs",
    "installCommand": "npm ci --legacy-peer-deps || npm install --legacy-peer-deps",
    "build": {
        "env": {
            "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
            "SKIP_ENV_VALIDATION": "true"
        }
    },
    "functions": {
        "pages/api/**/*.js": {
            "memory": 1024,
            "maxDuration": 10
        }
    }
}
